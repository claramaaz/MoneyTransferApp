@model IEnumerable<MoneyTransferApp.Models.Currency>
@{
    Layout = null; ViewData["Title"] = "Currencies";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Currencies - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @Html.Partial("_AdminNav")
    <div class="mm-container">

        <p class="mm-page-title">Currency Management</p>
        <p class="mm-page-subtitle">Update exchange rates for all supported currencies</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }

        <div class="mm-table-wrap">
            <div class="mm-table-header"><span class="th-title">Exchange Rates (base: USD)</span></div>
            <table class="mm-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Currency Name</th>
                        <th>Symbol</th>
                        <th>Exchange Rate (to USD)</th>
                        <th>Last Updated</th>
                        <th>Save</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <form asp-action="UpdateCurrency" method="post">
                            <tr>
                                <td>
                                    <span style="font-weight:700; font-family:monospace; font-size:0.95rem;">
                                        @(c.FlagEmoji ?? "") @c.Code
                                    </span>
                                </td>
                                <td>@c.Name</td>
                                <td style="color:var(--mm-muted);">@c.Symbol</td>
                                <td>
                                    <input type="hidden" name="code" value="@c.Code" />
                                    <input type="number" name="exchangeRate" value="@c.ExchangeRate"
                                           step="0.0001" min="0"
                                           style="width:130px;padding:6px 10px;border:1.5px solid var(--mm-border);border-radius:6px;font-size:0.88rem;" />
                                </td>
                                <td style="font-size:0.82rem; color:var(--mm-muted);">@c.LastUpdated.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <button type="submit" class="mm-btn mm-btn-teal mm-btn-sm">Save</button>
                                </td>
                            </tr>
                        </form>
                    }
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
