@* ============================================================
   Views/Admin/Agents.cshtml
   ============================================================ *@

@model IEnumerable<MoneyTransferApp.Models.Agent>
@using MoneyTransferApp.Models

@{
    Layout = null;
    ViewData["Title"] = "Agents";
    
    var pending = Model.Where(a => a.Status == AgentStatus.Pending).ToList();
    var approved = Model.Where(a => a.Status == AgentStatus.Approved).ToList();
    var rejected = Model.Where(a => a.Status == AgentStatus.Rejected || a.Status == AgentStatus.Suspended).ToList();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agents - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @Html.Partial("_AdminNav")

    <div class="mm-container">

        <p class="mm-page-title">Manage Agents</p>
        <p class="mm-page-subtitle">Approve, reject, and monitor all agent partner stores</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="mm-alert mm-alert-error">@ViewBag.Error</div>
        }

        @* ── Stats bar ── *@
        <div class="mm-stats-grid">
            <div class="mm-stat-card">
                <div class="sc-info">
                    <div class="sc-label">Pending Review</div>
                    <div class="sc-value" style="color:#f59e0b;">@pending.Count</div>
                </div>
                <div class="sc-icon orange">⏳</div>
            </div>
            <div class="mm-stat-card">
                <div class="sc-info">
                    <div class="sc-label">Approved Agents</div>
                    <div class="sc-value" style="color:var(--mm-teal);">@approved.Count</div>
                </div>
                <div class="sc-icon teal">✓</div>
            </div>
            <div class="mm-stat-card">
                <div class="sc-info">
                    <div class="sc-label">Rejected / Suspended</div>
                    <div class="sc-value" style="color:#ef4444;">@rejected.Count</div>
                </div>
                <div class="sc-icon orange" style="background:rgba(239,68,68,0.12); color:#ef4444;">✕</div>
            </div>
        </div>

        @* ══════════════════════════════════════════════
           SECTION 1 — PENDING APPLICATIONS
           ══════════════════════════════════════════════ *@
        @if (pending.Any())
        {
            <div class="mm-table-wrap" style="margin-bottom:28px;">
                <div class="mm-table-header">
                    <span class="th-title">
                        <span class="mm-badge pending">⏳ PENDING</span>
                        Applications Awaiting Review
                    </span>
                </div>

                <div style="padding:16px 20px; display:flex; flex-direction:column; gap:16px;">
                    @foreach (var agent in pending)
                    {
                        <div style="border:1px solid #fde68a; border-radius:10px; padding:18px; background:#fffbeb;">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px;">
                                <div style="flex:1; min-width:200px;">
                                    <div style="font-weight:700; font-size:1rem; margin-bottom:4px;">@agent.StoreName</div>
                                    <div style="font-size:0.85rem; color:#374151; margin-bottom:2px;">
                                        👤 <strong>@agent.OwnerName</strong>
                                        @if (agent.User != null)
                                        {
                                            <span style="color:var(--mm-muted);"> — @agent.User.Email</span>
                                        }
                                    </div>
                                    <div style="font-size:0.82rem; color:var(--mm-muted);">📍 @agent.Address</div>
                                    @if (!string.IsNullOrEmpty(agent.Phone))
                                    {
                                        <div style="font-size:0.82rem; color:var(--mm-muted);">📞 @agent.Phone</div>
                                    }
                                    @if (!string.IsNullOrEmpty(agent.WorkingHours))
                                    {
                                        <div style="font-size:0.82rem; color:var(--mm-muted);">🕐 @agent.WorkingHours</div>
                                    }
                                    <div style="font-size:0.75rem; color:#9ca3af; margin-top:6px;">
                                        Applied @agent.RegisteredAt.ToString("MMM dd, yyyy HH:mm")
                                    </div>
                                </div>

                                <div style="display:flex; gap:8px; align-items:center; flex-shrink:0;">
                                    <form asp-action="ApproveAgent" asp-route-id="@agent.Id" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="mm-btn mm-btn-teal mm-btn-sm"
                                                onclick="return confirm('Approve @agent.StoreName? This will grant them the Agent role.')">
                                            ✓ Approve
                                        </button>
                                    </form>
                                    <form asp-action="RejectAgent" asp-route-id="@agent.Id" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="mm-btn mm-btn-danger mm-btn-sm"
                                                onclick="return confirm('Reject this application?')">
                                            ✕ Reject
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="mm-table-wrap" style="text-align:center; padding:30px; margin-bottom:28px; color:var(--mm-muted);">
                <div style="font-size:1.8rem; margin-bottom:8px;">✅</div>
                <div>No pending applications</div>
            </div>
        }

        @* ══════════════════════════════════════════════
           SECTION 2 — APPROVED AGENTS
           ══════════════════════════════════════════════ *@
        @if (approved.Any())
        {
            <div class="mm-table-wrap" style="margin-bottom:28px;">
                <div class="mm-table-header">
                    <span class="th-title">
                        <span class="mm-badge approved">✓ APPROVED</span>
                        Active Agents
                    </span>
                </div>

                <div style="overflow-x:auto;">
                    <table class="mm-table">
                        <thead>
                            <tr>
                                <th>Store</th>
                                <th>Owner</th>
                                <th>Address</th>
                                <th>Approved</th>
                                <th style="text-align:right;">Commission</th>
                                <th style="text-align:center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var agent in approved)
                            {
                                <tr>
                                    <td style="font-weight:600;">@agent.StoreName</td>
                                    <td>@agent.OwnerName</td>
                                    <td style="color:var(--mm-muted);">@agent.Address</td>
                                    <td style="color:var(--mm-muted);">
                                        @(agent.ApprovedAt?.ToString("MMM dd, yyyy") ?? "-")
                                    </td>
                                    <td style="text-align:right; color:var(--mm-teal); font-weight:600;">
                                        $@agent.TotalCommissionEarned.ToString("F2")
                                    </td>
                                    <td style="text-align:center;">
                                        <form asp-action="RejectAgent" asp-route-id="@agent.Id" method="post" style="margin:0; display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="mm-btn mm-btn-outline mm-btn-sm" style="border-color:#ef4444; color:#ef4444;"
                                                    onclick="return confirm('Suspend this agent?')">
                                                Suspend
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ══════════════════════════════════════════════
           SECTION 3 — REJECTED / SUSPENDED
           ══════════════════════════════════════════════ *@
        @if (rejected.Any())
        {
            <div class="mm-table-wrap">
                <div class="mm-table-header">
                    <span class="th-title">
                        <span class="mm-badge rejected">✕ REJECTED / SUSPENDED</span>
                    </span>
                </div>

                <div style="overflow-x:auto;">
                    <table class="mm-table">
                        <thead>
                            <tr>
                                <th>Store</th>
                                <th>Owner</th>
                                <th>Status</th>
                                <th style="text-align:center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var agent in rejected)
                            {
                                <tr style="opacity:0.7;">
                                    <td style="font-weight:600;">@agent.StoreName</td>
                                    <td>@agent.OwnerName</td>
                                    <td>
                                        <span class="mm-badge @agent.Status.ToString().ToLower()">@agent.Status</span>
                                    </td>
                                    <td style="text-align:center;">
                                        <form asp-action="ApproveAgent" asp-route-id="@agent.Id" method="post" style="margin:0; display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="mm-btn mm-btn-outline mm-btn-sm" style="border-color:var(--mm-teal); color:var(--mm-teal);"
                                                    onclick="return confirm('Re-approve this agent?')">
                                                Re-approve
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>
</body>
</html>