@* ============================================================
   Views/Admin/Agents.cshtml
   ============================================================ *@

@model IEnumerable<MoneyTransferApp.Models.Agent>

@{
    Layout = null;
    ViewData["Title"] = "Agents";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agents - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @Html.Partial("_AdminNav")

    <div class="mm-container">

        <p class="mm-page-title">Manage Agents</p>
        <p class="mm-page-subtitle">Approve, reject, and monitor all agent partner stores</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }

        <div class="mm-table-wrap">
            <div class="mm-table-header">
                <span class="th-title">All Agents</span>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div style="padding:28px 20px; color:#6b7a8d; text-align:center;">No agents registered yet.</div>
            }
            else
            {
                <table class="mm-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Store Name</th>
                            <th>Owner</th>
                            <th>Address</th>
                            <th>Registered</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var agent in Model)
                        {
                            <tr>
                                <td style="font-family:monospace; font-size:0.83rem; color:#6b7a8d;">AGT-@agent.Id.ToString("D4")</td>
                                <td style="font-weight:600;">@agent.StoreName</td>
                                <td>@agent.OwnerName</td>
                                <td style="font-size:0.85rem; color:#6b7a8d;">@agent.Address</td>
                                <td style="font-size:0.83rem; color:#6b7a8d;">@agent.RegisteredAt.ToString("dd/MM/yyyy")</td>
                                <td><span class="mm-badge @agent.Status.ToString().ToLower()">@agent.Status</span></td>
                                <td>
                                    @if (agent.Status == MoneyTransferApp.Models.AgentStatus.Pending)
                                    {
                                        <form asp-action="ApproveAgent" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@agent.Id" />
                                            <button type="submit" class="mm-btn mm-btn-teal mm-btn-sm">Approve</button>
                                        </form>
                                        <form asp-action="RejectAgent" method="post" style="display:inline; margin-left:6px;">
                                            <input type="hidden" name="id" value="@agent.Id" />
                                            <button type="submit" class="mm-btn mm-btn-danger mm-btn-sm">Reject</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span style="color:#cbd5e0; font-size:0.85rem;">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>
</body>
</html>
