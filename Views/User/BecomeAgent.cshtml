@* ============================================================
   Views/User/BecomeAgent.cshtml
   Allows a user to apply to become an agent
   ============================================================ *@

@using MoneyTransferApp.Models

@{
    Layout = null;
    ViewData["Title"] = "Become an Agent";
    var alreadyApplied = ViewBag.AlreadyApplied as bool? ?? false;
    var agentStatus = ViewBag.AgentStatus;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Become an Agent - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @Html.Partial("_UserNav")

    <div class="mm-container">

        <p class="mm-page-title">Become an Agent</p>
        <p class="mm-page-subtitle">Join the Money Money partner network and earn commissions</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="mm-alert mm-alert-error">@ViewBag.Error</div>
        }

        @if (alreadyApplied)
        {
            <div class="mm-card" style="text-align:center; padding:40px 24px; max-width:500px; margin:0 auto;">
                <div style="font-size:3rem; margin-bottom:12px;">
                    @(agentStatus?.ToString() == "Approved" ? "✅" : agentStatus?.ToString() == "Rejected" ? "❌" : "⏳")
                </div>
                <div style="font-weight:700; font-size:1.1rem; margin-bottom:8px;">Application Status</div>
                <span class="mm-badge @(agentStatus?.ToString()?.ToLower() ?? "pending")" style="font-size:0.9rem; padding:6px 16px;">
                    @(agentStatus?.ToString() ?? "Pending")
                </span>
                <p style="font-size:0.88rem; color:#6b7a8d; margin-top:16px; line-height:1.6;">
                    @if (agentStatus?.ToString() == "Approved")
                    {
                        <span>Congratulations! Your application has been approved. Please log out and log back in to access the Agent Portal.</span>
                    }
                    else if (agentStatus?.ToString() == "Rejected")
                    {
                        <span>Your application was not approved. Please contact support for more information.</span>
                    }
                    else
                    {
                        <span>Your application is under review. You will be notified once an admin has processed it.</span>
                    }
                </p>
                <a asp-action="Dashboard" class="mm-btn mm-btn-outline" style="margin-top:12px;">Back to Dashboard</a>
            </div>
        }
        else
        {
            <div style="max-width:640px;">
                <div class="mm-card">
                    <form asp-action="ApplyAsAgent" asp-controller="User" method="post">

                        <div class="mm-form-group">
                            <label>Store Name <span style="color:#ef4444;">*</span></label>
                            <input type="text" name="storeName" placeholder="e.g. My Exchange Shop" required />
                        </div>

                        <div class="mm-form-group">
                            <label>Owner Name <span style="color:#ef4444;">*</span></label>
                            <input type="text" name="ownerName" placeholder="Your full legal name" required />
                        </div>

                        <div class="mm-form-grid-2">
                            <div class="mm-form-group">
                                <label>Phone Number <span style="color:#ef4444;">*</span></label>
                                <input type="text" name="phone" placeholder="+961 70 000 000" required />
                            </div>
                            <div class="mm-form-group">
                                <label>Working Hours <span style="color:#ef4444;">*</span></label>
                                <input type="text" name="workingHours" placeholder="Mon-Sat 9AM-6PM" required />
                            </div>
                        </div>

                        <div class="mm-form-group">
                            <label>Store Address <span style="color:#ef4444;">*</span></label>
                            <input type="text" name="address" placeholder="Full address of your store" required />
                        </div>

                        <div class="mm-form-grid-2">
                            <div class="mm-form-group">
                                <label>Latitude</label>
                                <input type="number" name="latitude" step="0.0001" value="33.8938" placeholder="33.8938" />
                            </div>
                            <div class="mm-form-group">
                                <label>Longitude</label>
                                <input type="number" name="longitude" step="0.0001" value="35.5018" placeholder="35.5018" />
                            </div>
                        </div>

                        <div class="mm-alert mm-alert-info" style="margin-bottom:16px; font-size:0.83rem;">
                            By submitting this form, your application will be reviewed by an admin. You will receive an in-app notification once approved.
                        </div>

                        <div style="display:flex; gap:12px;">
                            <button type="submit" class="mm-btn mm-btn-teal">Submit Application</button>
                            <a asp-action="Profile" class="mm-btn mm-btn-outline">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>
        }

    </div>
</body>
</html>
