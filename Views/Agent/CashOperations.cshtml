@* ============================================================
   Views/Agent/CashOperations.cshtml
   BUG 3 FIX : name="customerAccount" (pas recipientAccount/senderAccount)
   ============================================================ *@

@{
    Layout = null;
    ViewData["Title"] = "Cash Operations";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cash Operations - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @Html.Partial("_AgentNav")

    <div class="mm-container">

        <p class="mm-page-title">Cash Operations</p>
        <p class="mm-page-subtitle">Process cash-in and cash-out for your customers</p>

        @* BUG 3 FIX : TempData affiché via ViewBag (passé depuis le controller) *@
        @if (ViewBag.Error != null)
        {
            <div class="mm-alert mm-alert-error">@ViewBag.Error</div>
        }
        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">

            @* ─── CASH IN ─── *@
            <div class="mm-card">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
                    <div style="width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;background:#00b48c;color:white;">↓</div>
                    <div>
                        <div style="font-weight:700; font-size:1.05rem;">Cash-In</div>
                        <div style="font-size:0.8rem;color:#6b7a8d;">Deposit funds to an account</div>
                    </div>
                </div>
                <form asp-action="CashIn" asp-controller="Agent" method="post">

                    <div class="mm-form-group">
                        <label>Recipient Account Number</label>
                        @* BUG 3 FIX : name="customerAccount" (correspond au paramètre du controller) *@
                        <input type="text" name="customerAccount" placeholder="ACC-2026-XXXXX" required />
                    </div>

                    <div class="mm-form-group">
                        <label>Amount</label>
                        <input type="number" name="amount" step="0.01" min="0.01" placeholder="0.00" required />
                    </div>

                    <div class="mm-form-group">
                        <label>Currency</label>
                        @* BUG 4 FIX : la devise est maintenant bien prise en compte dans le controller *@
                        <select name="currency">
                            <option value="USD">🇺🇸 USD — US Dollar</option>
                            <option value="EUR">🇪🇺 EUR — Euro</option>
                            <option value="LBP">🇱🇧 LBP — Lebanese Pound</option>
                            <option value="AED">🇦🇪 AED — UAE Dirham</option>
                            <option value="SAR">🇸🇦 SAR — Saudi Riyal</option>
                            <option value="GBP">🇬🇧 GBP — British Pound</option>
                        </select>
                    </div>

                    <button type="submit" class="mm-btn mm-btn-teal mm-btn-full">Process Cash-In</button>
                </form>
            </div>

            @* ─── CASH OUT ─── *@
            <div class="mm-card">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
                    <div style="width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;background:#1490dc;color:white;">↑</div>
                    <div>
                        <div style="font-weight:700; font-size:1.05rem;">Cash-Out</div>
                        <div style="font-size:0.8rem;color:#6b7a8d;">Withdraw funds from an account</div>
                    </div>
                </div>
                <form asp-action="CashOut" asp-controller="Agent" method="post">

                    <div class="mm-form-group">
                        <label>Sender Account Number</label>
                        @* BUG 3 FIX : name="customerAccount" (correspond au paramètre du controller) *@
                        <input type="text" name="customerAccount" placeholder="ACC-2026-XXXXX" required />
                    </div>

                    <div class="mm-form-group">
                        <label>Amount</label>
                        <input type="number" name="amount" step="0.01" min="0.01" placeholder="0.00" required />
                    </div>

                    <div class="mm-form-group">
                        <label>Currency</label>
                        <select name="currency">
                            <option value="USD">🇺🇸 USD — US Dollar</option>
                            <option value="EUR">🇪🇺 EUR — Euro</option>
                            <option value="LBP">🇱🇧 LBP — Lebanese Pound</option>
                            <option value="AED">🇦🇪 AED — UAE Dirham</option>
                            <option value="SAR">🇸🇦 SAR — Saudi Riyal</option>
                            <option value="GBP">🇬🇧 GBP — British Pound</option>
                        </select>
                    </div>

                    <button type="submit" class="mm-btn mm-btn-primary mm-btn-full">Process Cash-Out</button>
                </form>
            </div>

        </div>

        @* Info box : explication de la conversion *@
        <div class="mm-alert mm-alert-info" style="margin-top:8px;">
            <strong>Note :</strong> Amounts entered in non-USD currencies are automatically converted
            using the exchange rates configured by the admin. The customer's balance is always
            updated in USD equivalent.
        </div>

    </div>
</body>
</html>
