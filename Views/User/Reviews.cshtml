@* ============================================================
   Views/User/Reviews.cshtml
   Model: IEnumerable<MoneyTransferApp.Models.Review>
   ============================================================ *@

@model IEnumerable<MoneyTransferApp.Models.Review>

@{
    Layout = null;
    ViewData["Title"] = "Reviews";
    var avgRating = Model != null && Model.Any() ? Model.Average(r => r.Rating) : 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reviews - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .star-rating {
            display: flex;
            gap: 6px;
        }

        .star-btn {
            font-size: 1.6rem;
            cursor: pointer;
            background: none;
            border: none;
            color: #d1d5db;
            transition: color 0.15s;
            padding: 0;
        }

            .star-btn.active, .star-btn:hover {
                color: #f59e0b;
            }

        .review-card {
            padding: 18px 20px;
            border-bottom: 1px solid var(--mm-border);
        }

            .review-card:last-child {
                border-bottom: none;
            }
    </style>
</head>
<body>

    @Html.Partial("_UserNav")

    <div class="mm-container">

        <p class="mm-page-title">Service Reviews</p>
        <p class="mm-page-subtitle">See what users think of Money Money — and share your experience</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="mm-alert mm-alert-error">@ViewBag.Error</div>
        }

        <div style="display:grid; grid-template-columns:1fr 340px; gap:24px; align-items:start;">

            @* ── Reviews List ── *@
            <div>
                @* Summary bar *@
                @if (Model != null && Model.Any())
                {
                    <div class="mm-card" style="margin-bottom:20px; display:flex; align-items:center; gap:24px;">
                        <div style="text-align:center;">
                            <div style="font-size:3rem; font-weight:800; color:var(--mm-text);">@avgRating.ToString("F1")</div>
                            <div style="font-size:1.2rem; color:#f59e0b;">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span>@(i <= Math.Round(avgRating) ? "★" : "☆")</span>
                                }
                            </div>
                            <div style="font-size:0.82rem; color:#6b7a8d;">@Model.Count() reviews</div>
                        </div>
                        <div style="flex:1;">
                            @for (int star = 5; star >= 1; star--)
                            {
                                var count = Model.Count(r => r.Rating == star);
                                var pct = Model.Any() ? (count * 100 / Model.Count()) : 0;
                                <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px; font-size:0.82rem;">
                                    <span style="width:12px;">@star</span>
                                    <span style="color:#f59e0b;">★</span>
                                    <div style="flex:1; height:8px; background:#e2e8f0; border-radius:4px; overflow:hidden;">
                                        <div style="width:@pct%; height:100%; background:#f59e0b; border-radius:4px;"></div>
                                    </div>
                                    <span style="width:24px; color:#6b7a8d;">@count</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="mm-table-wrap">
                    <div class="mm-table-header">
                        <span class="th-title">All Reviews</span>
                    </div>

                    @if (Model == null || !Model.Any())
                    {
                        <div style="padding:40px 20px; color:#6b7a8d; text-align:center;">
                            <div style="font-size:2rem; margin-bottom:10px;">⭐</div>
                            <div>No reviews yet. Be the first to share your experience!</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var r in Model)
                        {
                            <div class="review-card">
                                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <div style="width:36px;height:36px;border-radius:50%;background:rgba(20,144,220,0.12);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--mm-blue);">
                                            @(r.User?.FullName?.Length > 0 ? r.User.FullName[0].ToString().ToUpper() : "?")
                                        </div>
                                        <div>
                                            <div style="font-weight:600; font-size:0.9rem;">@(r.User?.FullName ?? "Anonymous")</div>
                                            <div style="font-size:0.75rem; color:#6b7a8d;">@r.CreatedAt.ToString("dd MMM yyyy")</div>
                                        </div>
                                    </div>
                                    <div style="color:#f59e0b; font-size:1rem;">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span>@(i <= r.Rating ? "★" : "☆")</span>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(r.Comment))
                                {
                                    <p style="font-size:0.88rem; color:var(--mm-text); line-height:1.6; margin:0;">@r.Comment</p>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

            @* ── Add Review Form ── *@
            <div class="mm-card" style="position:sticky; top:80px;">
                <div style="font-weight:700; font-size:1rem; margin-bottom:16px;">✍️ Write a Review</div>

                <form asp-action="AddReview" asp-controller="User" method="post">

                    <div class="mm-form-group">
                        <label>Your Rating</label>
                        <div class="star-rating" id="starRating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <button type="button" class="star-btn" data-value="@i" onclick="setRating(@i)">★</button>
                            }
                        </div>
                        <input type="hidden" name="rating" id="ratingInput" value="5" />
                        <div style="font-size:0.78rem; color:#6b7a8d; margin-top:4px;" id="ratingLabel">5 stars — Excellent!</div>
                    </div>

                    <div class="mm-form-group">
                        <label>Comment <span style="color:#6b7a8d; font-weight:400;">(optional)</span></label>
                        <textarea name="comment" rows="4" placeholder="Share your experience with Money Money..."
                                  style="resize:vertical;"></textarea>
                    </div>

                    <button type="submit" class="mm-btn mm-btn-primary mm-btn-full">Submit Review</button>

                </form>
            </div>

        </div>
    </div>

    <script>
        var labels = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent!'];
        var current = 5;

        function setRating(value) {
            current = value;
            document.getElementById('ratingInput').value = value;
            document.getElementById('ratingLabel').textContent = value + ' stars — ' + labels[value];
            var stars = document.querySelectorAll('.star-btn');
            stars.forEach(function(btn, idx) {
                btn.classList.toggle('active', idx < value);
            });
        }

        // Init with 5 stars active
        setRating(5);
    </script>

</body>
</html>
