@model IEnumerable<MoneyTransferApp.Models.Transaction>
@{
    Layout = null; ViewData["Title"] = "My Commissions";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Commissions - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @Html.Partial("_AgentNav")
    <div class="mm-container">
        <p class="mm-page-title">My Commissions</p>
        <p class="mm-page-subtitle">Track your earnings from all cash operations</p>

        <div class="mm-stats-grid" style="max-width:440px;">
            <div class="mm-stat-card">
                <div class="sc-info"><div class="sc-label">Total Earned (USD)</div><div class="sc-value" style="color:var(--mm-teal);">@ViewBag.TotalCommission</div></div>
                <div class="sc-icon teal">&#36;</div>
            </div>
            <div class="mm-stat-card">
                <div class="sc-info"><div class="sc-label">Total Operations</div><div class="sc-value">@(Model?.Count() ?? 0)</div></div>
                <div class="sc-icon blue">&#8645;</div>
            </div>
        </div>

        <div class="mm-table-wrap">
            <div class="mm-table-header"><span class="th-title">Commission History</span></div>
            @if (Model == null || !Model.Any())
            {
                <div style="padding:28px 20px; color:#6b7a8d; text-align:center;">No commissions yet.</div>
            }
            else
            {
                <table class="mm-table">
                    <thead>
                        <tr><th>Transaction</th><th>Amount</th><th>Currency</th><th>USD Equiv.</th><th>Type</th><th>Commission Earned</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td style="font-family:monospace; font-size:0.85rem;">@t.SerialNumber</td>
                                <td>@t.Amount.ToString("F2")</td>
                                <td>@t.FromCurrency</td>
                                <td style="color:var(--mm-teal);">@t.ConvertedAmount.ToString("F2")</td>
                                <td><span class="mm-badge active">@t.Type</span></td>
                                <td style="color:var(--mm-teal); font-weight:600;">+@t.CommissionAmount.ToString("F2")</td>
                                <td style="color:#6b7a8d; font-size:0.85rem;">@t.CreatedAt.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</body>
</html>
