@model IEnumerable<MoneyTransferApp.Models.User>
@{
    Layout = null; ViewData["Title"] = "Users";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Users - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @Html.Partial("_AdminNav")
    <div class="mm-container">
        <p class="mm-page-title">All Users</p>
        <p class="mm-page-subtitle">Manage all registered users on the platform</p>

        <div class="mm-table-wrap">
            <div class="mm-table-header">
                <span class="th-title">User Accounts</span>
                <span style="font-size:0.85rem; color:var(--mm-muted);">@(Model?.Count() ?? 0) total</span>
            </div>
            @if (Model == null || !Model.Any())
            {
                <div style="padding:28px 20px; color:#6b7a8d; text-align:center;">No users registered yet.</div>
            }
            else
            {
                <table class="mm-table">
                    <thead>
                        <tr><th>Full Name</th><th>Email</th><th>Account Number</th><th>Balance (USD)</th><th>Currency</th><th>Joined</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <div style="width:34px;height:34px;border-radius:50%;background:rgba(20,144,220,0.12);display:flex;align-items:center;justify-content:center;font-size:0.85rem;font-weight:700;color:var(--mm-blue);flex-shrink:0;">
                                            @(u.FullName?.Length > 0 ? u.FullName[0].ToString().ToUpper() : "?")
                                        </div>
                                        <span style="font-weight:500;">@u.FullName</span>
                                    </div>
                                </td>
                                <td style="color:var(--mm-muted); font-size:0.88rem;">@u.Email</td>
                                <td style="font-family:monospace; font-size:0.85rem;">@u.AccountNumber</td>
                                <td style="font-weight:600; color:var(--mm-teal);">@u.Balance.ToString("F2")</td>
                                <td><span class="mm-badge active">@u.PreferredCurrency</span></td>
                                <td style="font-size:0.83rem; color:var(--mm-muted);">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</body>
</html>
