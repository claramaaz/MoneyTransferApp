@model IEnumerable<MoneyTransferApp.Models.Review>
@{ Layout = null; ViewData["Title"] = "Reviews"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reviews - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .stars-input { display:flex; flex-direction:row-reverse; justify-content:flex-end; gap:4px; margin:8px 0; }
        .stars-input input { display:none; }
        .stars-input label { font-size:2rem; color:#d1d5db; cursor:pointer; transition:color 0.1s; }
        .stars-input input:checked ~ label,
        .stars-input label:hover,
        .stars-input label:hover ~ label { color:#f59e0b; }
    </style>
</head>
<body>
@Html.Partial("_UserNav")
<div class="mm-container">

    <p class="mm-page-title">Reviews & Ratings</p>
    <p class="mm-page-subtitle">Share your experience with Money Money</p>

    @if (ViewBag.Success != null) { <div class="mm-alert mm-alert-success">@ViewBag.Success</div> }
    @if (TempData["Error"] != null) { <div class="mm-alert mm-alert-error">@TempData["Error"]</div> }

    <div style="display:grid; grid-template-columns:1fr 360px; gap:24px; align-items:start;">

        @* ── Liste des reviews ── *@
        <div>
            @if (Model == null || !Model.Any())
            {
                <div class="mm-card" style="text-align:center;color:#6b7a8d;padding:40px;">
                    No reviews yet. Be the first to rate!
                </div>
            }
            else
            {
                @foreach (var r in Model)
                {
                    <div class="mm-card" style="margin-bottom:12px;">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div style="width:38px;height:38px;border-radius:50%;background:rgba(20,144,220,0.12);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.95rem;color:var(--mm-blue);">
                                    @(r.User?.FullName?.Length > 0 ? r.User.FullName[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div style="font-weight:600;font-size:0.9rem;">@(r.User?.FullName ?? "Anonymous")</div>
                                    <div style="font-size:0.75rem;color:#6b7a8d;">@r.CreatedAt.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                            <div style="color:#f59e0b;font-size:1.1rem;letter-spacing:2px;">
                                @string.Concat(Enumerable.Repeat("★", r.Rating))@string.Concat(Enumerable.Repeat("☆", 5 - r.Rating))
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(r.Comment))
                        {
                            <p style="margin-top:10px;font-size:0.88rem;color:#4a5568;line-height:1.6;">@r.Comment</p>
                        }
                    </div>
                }
            }
        </div>

        @* ── Formulaire d'avis ── *@
        <div class="mm-card">
            <div style="font-weight:700;font-size:1rem;margin-bottom:16px;">Rate Our Service</div>
            <form asp-action="AddReview" asp-controller="User" method="post">
                <div class="mm-form-group">
                    <label>Your Rating</label>
                    <div class="stars-input">
                        <input type="radio" name="rating" id="s5" value="5" /><label for="s5">★</label>
                        <input type="radio" name="rating" id="s4" value="4" /><label for="s4">★</label>
                        <input type="radio" name="rating" id="s3" value="3" checked /><label for="s3">★</label>
                        <input type="radio" name="rating" id="s2" value="2" /><label for="s2">★</label>
                        <input type="radio" name="rating" id="s1" value="1" /><label for="s1">★</label>
                    </div>
                </div>
                <div class="mm-form-group">
                    <label>Your Comment (optional)</label>
                    <textarea name="comment" rows="4"
                              style="width:100%;padding:10px 14px;border:1.5px solid #e2e8f0;border-radius:8px;font-family:inherit;font-size:0.88rem;resize:vertical;"
                              placeholder="Share your experience..."></textarea>
                </div>
                <button type="submit" class="mm-btn mm-btn-primary mm-btn-full">Submit Review</button>
            </form>
        </div>

    </div>

</div>
</body>
</html>
