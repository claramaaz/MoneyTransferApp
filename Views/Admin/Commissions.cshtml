@model IEnumerable<MoneyTransferApp.Models.Commission>
@{
    Layout = null; ViewData["Title"] = "Commissions";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Commissions - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @Html.Partial("_AdminNav")
    <div class="mm-container">

        <p class="mm-page-title">Commission Structure</p>
        <p class="mm-page-subtitle">Manage transfer commission tiers and agent/platform splits</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }

        <div class="mm-table-wrap">
            <div class="mm-table-header"><span class="th-title">Commission Tiers</span></div>

            @if (Model == null || !Model.Any())
            {
                <div style="padding:28px 20px; color:#6b7a8d; text-align:center;">No commission tiers defined.</div>
            }
            else
            {
                <table class="mm-table">
                    <thead>
                        <tr>
                            <th>Tier</th>
                            <th>Min Amount ($)</th>
                            <th>Max Amount ($)</th>
                            <th>Total Rate (%)</th>
                            <th>Agent Share (%)</th>
                            <th>Platform Share (%)</th>
                            <th>Save</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <form asp-action="UpdateCommission" method="post">
                                <tr>
                                    <td style="font-weight:600;">@(c.Label ?? $"${c.MinAmount}–${c.MaxAmount}")</td>
                                    <td>@c.MinAmount</td>
                                    <td>@c.MaxAmount</td>
                                    <td style="color:var(--mm-blue); font-weight:600;">@c.Rate%</td>
                                    <td>
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <input type="number" name="agentShare" value="@c.AgentShare" step="0.01" min="0" max="100"
                                               style="width:80px;padding:5px 8px;border:1.5px solid var(--mm-border);border-radius:6px;font-size:0.88rem;" />
                                    </td>
                                    <td style="color:var(--mm-teal); font-weight:600;">@c.PlatformShare%</td>
                                    <td>
                                        <button type="submit" class="mm-btn mm-btn-primary mm-btn-sm">Save</button>
                                    </td>
                                </tr>
                            </form>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</body>
</html>
