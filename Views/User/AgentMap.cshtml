@model IEnumerable<MoneyTransferApp.Models.Agent>
@{ Layout = null; ViewData["Title"] = "Find Agents"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Find Agents - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map { height: 480px; border-radius: 14px; border: 1.5px solid #e2e8f0; z-index: 0; }
        .agent-card { background:white; border-radius:12px; border:1px solid #e2e8f0; padding:12px 16px; margin-bottom:10px; cursor:pointer; transition:border-color 0.15s, box-shadow 0.15s; }
        .agent-card:hover { border-color:#00b48c; box-shadow:0 2px 12px rgba(0,180,140,0.12); }
        .agent-card.active { border-color:var(--mm-blue); background:rgba(20,144,220,0.04); }
    </style>
</head>
<body>
@Html.Partial("_UserNav")
<div class="mm-container">

    <p class="mm-page-title">Find Agents Near You</p>
    <p class="mm-page-subtitle">All approved Money Money partner stores</p>

    <div style="display:grid; grid-template-columns:1fr 320px; gap:24px; align-items:start;">

        <div class="mm-card" style="padding:0;overflow:hidden;">
            <div id="map"></div>
        </div>

        <div>
            <div style="font-weight:600;font-size:0.95rem;margin-bottom:12px;color:#1a2332;">
                @(Model?.Count() ?? 0) Agents Available
            </div>
            @if (Model != null)
            {
                @foreach (var a in Model)
                {
                    <div class="agent-card" id="card-@a.Id"
                         onclick="focusAgent(@a.Latitude, @a.Longitude, @a.Id)">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                            <div>
                                <div style="font-weight:600;font-size:0.9rem;">@a.StoreName</div>
                                <div style="font-size:0.78rem;color:#6b7a8d;margin-top:2px;">@a.Address</div>
                                @if (!string.IsNullOrEmpty(a.WorkingHours))
                                {
                                    <div style="font-size:0.75rem;color:#00b48c;margin-top:3px;">🕐 @a.WorkingHours</div>
                                }
                                @if (!string.IsNullOrEmpty(a.Phone))
                                {
                                    <div style="font-size:0.75rem;color:#1490dc;margin-top:2px;">📞 @a.Phone</div>
                                }
                            </div>
                            <span class="mm-badge approved" style="font-size:0.7rem;flex-shrink:0;">Open</span>
                        </div>
                    </div>
                }
            }
        </div>

    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    var map = L.map('map').setView([33.8938, 35.5018], 9);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19
    }).addTo(map);

    function makeIcon() {
        return L.divIcon({
            html: '<div style="background:#00b48c;width:16px;height:16px;border-radius:50%;border:3px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3);"></div>',
            iconSize:[16,16], iconAnchor:[8,8], className:''
        });
    }

    var markers = {};
    var agents = [
        @if (Model != null)
        {
            @foreach (var a in Model)
            {
                <text>{ id:@a.Id, name:"@a.StoreName", address:"@a.Address", phone:"@(a.Phone ?? "")", hours:"@(a.WorkingHours ?? "")", lat:@a.Latitude, lng:@a.Longitude },</text>
            }
        }
    ];

    agents.forEach(function(a) {
        var m = L.marker([a.lat, a.lng], { icon: makeIcon() }).addTo(map)
            .bindPopup(
                '<div style="min-width:170px;">' +
                '<strong style="font-size:13px;">' + a.name + '</strong><br>' +
                '<span style="font-size:12px;color:#6b7a8d;">' + a.address + '</span>' +
                (a.phone ? '<br><span style="font-size:12px;color:#1490dc;">📞 ' + a.phone + '</span>' : '') +
                (a.hours ? '<br><span style="font-size:12px;color:#00b48c;">🕐 ' + a.hours + '</span>' : '') +
                '</div>'
            );
        markers[a.id] = m;
    });

    function focusAgent(lat, lng, id) {
        document.querySelectorAll('.agent-card').forEach(c => c.classList.remove('active'));
        var card = document.getElementById('card-' + id);
        if (card) { card.classList.add('active'); card.scrollIntoView({ behavior:'smooth', block:'nearest' }); }
        map.setView([lat, lng], 15, { animate: true });
        if (markers[id]) markers[id].openPopup();
    }
</script>
</body>
</html>
