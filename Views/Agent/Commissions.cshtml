@* ============================================================
   Views/Agent/Commissions.cshtml
   ============================================================ *@

@model IEnumerable<MoneyTransferApp.Models.Transaction>

@{
    ViewData["Title"] = "My Commissions";
}

@Html.Partial("_AgentNav")

<div class="container">

    <h2>My Commissions</h2>

    <div class="stats-grid" style="grid-template-columns: repeat(2, 1fr); max-width:420px;">
        <div class="stat-card">
            <div class="number">$@ViewBag.TotalCommission</div>
            <div class="label">Total Earned</div>
        </div>
        <div class="stat-card" style="border-top-color:#1565c0;">
            <div class="number" style="color:#1565c0;">@(Model?.Count() ?? 0)</div>
            <div class="label">Total Operations</div>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card"><p style="color:#888;">No commissions yet.</p></div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Transaction</th>
                    <th>Amount</th>
                    <th>Type</th>
                    <th>Commission Earned</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td>@t.SerialNumber</td>
                        <td>@t.Amount @t.FromCurrency</td>
                        <td>@t.Type</td>
                        <td style="color:#2e7d32; font-weight:600;">$@t.CommissionAmount</td>
                        <td>@t.CreatedAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
