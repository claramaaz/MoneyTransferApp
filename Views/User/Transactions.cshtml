@model IEnumerable<MoneyTransferApp.Models.Transaction>
@{
    Layout = null; ViewData["Title"] = "Transactions";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Transactions - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @Html.Partial("_UserNav")
    <div class="mm-container">

        <p class="mm-page-title">Transaction History</p>
        <p class="mm-page-subtitle">All your transfers, top-ups and receipts</p>

        <div class="mm-table-wrap">
            <div class="mm-table-header">
                <span class="th-title">All Transactions</span>
                <span style="font-size:0.85rem;color:var(--mm-muted);">@(Model?.Count() ?? 0) total</span>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div style="padding:28px 20px; color:#6b7a8d; text-align:center;">
                    No transactions yet. <a asp-action="Transfer">Make your first transfer →</a>
                </div>
            }
            else
            {
                <table class="mm-table">
                    <thead>
                        <tr>
                            <th>Serial Number</th>
                            <th>Amount</th>
                            <th>USD Equiv.</th>
                            <th>From / To</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td style="font-family:monospace;font-size:0.83rem;">@t.SerialNumber</td>
                                <td style="font-weight:600;">@t.Amount.ToString("F2") @t.FromCurrency</td>
                                <td style="color:var(--mm-teal);">@t.ConvertedAmount.ToString("F2")</td>
                                <td style="font-size:0.83rem;color:#6b7a8d;">
                                    @(t.Sender?.FullName ?? "—") → @(t.Recipient?.FullName ?? t.RecipientName ?? t.RecipientPhone ?? "—")
                                </td>
                                <td><span class="mm-badge active">@t.Type</span></td>
                                <td><span class="mm-badge @t.Status.ToString().ToLower()">@t.Status</span></td>
                                <td style="font-size:0.83rem;color:#6b7a8d;">@t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>
</body>
</html>
