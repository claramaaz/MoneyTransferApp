@{
    Layout = null; ViewData["Title"] = "Top Up";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Top Up - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @Html.Partial("_UserNav")
    <div class="mm-container">

        <p class="mm-page-title">Top Up Account</p>
        <p class="mm-page-subtitle">Add funds to your Money Money account</p>

        @if (ViewBag.Error != null)
        {
            <div class="mm-alert mm-alert-error">@ViewBag.Error</div>
        }
        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }

        <div class="mm-card" style="max-width:480px;">

            <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
                <div style="width:46px;height:46px;border-radius:12px;background:var(--mm-teal);color:white;display:flex;align-items:center;justify-content:center;font-size:1.4rem;">&#43;</div>
                <div>
                    <div style="font-weight:700;font-size:1.05rem;">Add Funds via Stripe</div>
                    <div style="font-size:0.82rem;color:#6b7a8d;">Secure payment — funds added instantly</div>
                </div>
            </div>

            <form asp-action="TopUp" asp-controller="User" method="post">

                <div class="mm-form-group">
                    <label>Amount</label>
                    <input type="number" name="amount" id="topupAmt" step="0.01" min="1"
                           placeholder="0.00" oninput="calcTopUp()" required />
                </div>

                <div class="mm-form-group">
                    <label>Currency</label>
                    <select name="currency" id="topupCurr" onchange="calcTopUp()">
                        @if (ViewBag.Currencies != null)
                        {
                            @foreach (var c in (List<MoneyTransferApp.Models.Currency>)ViewBag.Currencies)
                            {
                                <option value="@c.Code" data-rate="@c.ExchangeRate">@c.FlagEmoji @c.Code — @c.Name</option>
                            }
                        }
                    </select>
                </div>

                <div id="topupPreview" style="display:none; background:rgba(0,180,140,0.07); border-radius:8px; padding:12px 16px; margin-bottom:16px; border:1px solid rgba(0,180,140,0.2);">
                    <div style="font-size:0.82rem;color:#6b7a8d;">You will receive:</div>
                    <div style="font-size:1.4rem;font-weight:700;color:var(--mm-teal);" id="topupUSD">0.00 USD</div>
                </div>

                <button type="submit" class="mm-btn mm-btn-teal mm-btn-full">Add Funds</button>

            </form>

            <div class="mm-alert mm-alert-info" style="margin-top:14px; font-size:0.78rem;">
                <strong>Note:</strong> This is a simulated top-up for demo purposes.
                In production, this integrates with Stripe Payment Gateway.
            </div>

        </div>

    </div>
    <script>
            function calcTopUp() {
                var amt  = parseFloat(document.getElementById('topupAmt').value) || 0;
                var sel  = document.getElementById('topupCurr');
                var rate = parseFloat(sel.options[sel.selectedIndex].getAttribute('data-rate')) || 1;
                var usd  = (amt / rate).toFixed(2);
                document.getElementById('topupPreview').style.display = amt > 0 ? 'block' : 'none';
                document.getElementById('topupUSD').textContent = usd + ' USD';
            }
    </script>
</body>
</html>
