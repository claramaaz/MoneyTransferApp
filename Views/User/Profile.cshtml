@model MoneyTransferApp.Models.User
@{
    Layout = null; ViewData["Title"] = "Profile";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @Html.Partial("_UserNav")
    <div class="mm-container">

        <p class="mm-page-title">My Profile</p>
        <p class="mm-page-subtitle">Your account details</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;">

            <div class="mm-card">
                <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
                    <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,var(--mm-blue),var(--mm-teal));display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;color:white;">
                        @(Model?.FullName?.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "?")
                    </div>
                    <div>
                        <div style="font-size:1.15rem;font-weight:700;">@Model.FullName</div>
                        <div style="font-size:0.85rem;color:#6b7a8d;">@Model.Email</div>
                    </div>
                </div>
                <div style="border-top:1px solid #e2e8f0;padding-top:16px;">
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:0.5px solid #f0f4f8;font-size:0.88rem;">
                        <span style="color:#6b7a8d;">Account Number</span><strong>@Model.AccountNumber</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:0.5px solid #f0f4f8;font-size:0.88rem;">
                        <span style="color:#6b7a8d;">Balance (USD)</span><strong style="color:var(--mm-teal);">@Model.Balance.ToString("F2")</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:0.5px solid #f0f4f8;font-size:0.88rem;">
                        <span style="color:#6b7a8d;">Preferred Currency</span><strong>@Model.PreferredCurrency</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:0.88rem;">
                        <span style="color:#6b7a8d;">Member Since</span><strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong>
                    </div>
                </div>
            </div>

            <div>
                <div class="mm-card" style="margin-bottom:16px;">
                    <div style="font-weight:700;font-size:1rem;margin-bottom:16px;">Update Preferences</div>
                    <form asp-action="UpdateProfile" asp-controller="User" method="post">
                        <div class="mm-form-group">
                            <label>Preferred Currency</label>
                            <select name="preferredCurrency">
                                @if (ViewBag.Currencies != null)
                                {
                                    @foreach (var c in (List<MoneyTransferApp.Models.Currency>)ViewBag.Currencies)
                                    {
                                        if (c.Code == Model.PreferredCurrency)
                                        {
                                            <option value="@c.Code" selected>@c.FlagEmoji @c.Code — @c.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@c.Code">@c.FlagEmoji @c.Code — @c.Name</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                        <button type="submit" class="mm-btn mm-btn-primary">Save Changes</button>
                    </form>
                </div>

                <div class="mm-card">
                    <div style="font-weight:700;font-size:1rem;margin-bottom:12px;">Quick Links</div>
                    <a asp-action="Transactions" class="mm-btn mm-btn-outline mm-btn-full" style="margin-bottom:8px;display:block;text-align:center;">View Transaction History</a>
                    <a asp-action="Beneficiaries" class="mm-btn mm-btn-outline mm-btn-full" style="margin-bottom:8px;display:block;text-align:center;">Manage Beneficiaries</a>
                    <a asp-action="BecomeAgent" class="mm-btn mm-btn-outline mm-btn-full" style="display:block;text-align:center;">Become an Agent</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
