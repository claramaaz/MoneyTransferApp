@* ============================================================
   Views/Agent/Settings.cshtml
   BUG 1 FIX : page accessible depuis nav + dashboard
   BUG 2 FIX : asp-action="Settings" (pas "UpdateProfile")
               + hidden input name="id" pour retrouver l'agent
   ============================================================ *@

@model MoneyTransferApp.Models.Agent

@{
    Layout = null;
    ViewData["Title"] = "Agent Settings";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agent Settings - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @Html.Partial("_AgentNav")

    <div class="mm-container">

        <p class="mm-page-title">Agent Settings</p>
        <p class="mm-page-subtitle">Update your store profile and location details</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }

        @if (Model != null)
        {
            <div class="mm-card" style="max-width:600px;">

                @* BUG 2 FIX : asp-action="Settings" (correspond au [HttpPost] Settings() du controller) *@
                <form asp-action="Settings" asp-controller="Agent" method="post">

                    @* BUG 2 FIX : hidden input pour passer l'Id au controller (FindAsync(id)) *@
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mm-form-group">
                        <label>Store Name</label>
                        <input type="text" name="storeName" value="@Model.StoreName" required />
                    </div>

                    <div class="mm-form-group">
                        <label>Address</label>
                        <input type="text" name="address" value="@Model.Address" />
                    </div>

                    <div class="mm-form-group">
                        <label>Phone Number</label>
                        <input type="text" name="phone" value="@Model.Phone" placeholder="+961 ..." />
                    </div>

                    <div class="mm-form-group">
                        <label>Working Hours</label>
                        <input type="text" name="workingHours" value="@Model.WorkingHours"
                               placeholder="e.g. Mon-Fri 9AM-6PM, Sat 10AM-4PM" />
                    </div>

                    <div class="mm-form-grid-2">
                        <div class="mm-form-group">
                            <label>Latitude</label>
                            <input type="number" name="latitude" step="0.0001" value="@Model.Latitude" />
                        </div>
                        <div class="mm-form-group">
                            <label>Longitude</label>
                            <input type="number" name="longitude" step="0.0001" value="@Model.Longitude" />
                        </div>
                    </div>

                    <div style="display:flex; gap:10px; margin-top:8px;">
                        <button type="submit" class="mm-btn mm-btn-teal">Save Changes</button>
                        <a asp-action="Dashboard" class="mm-btn mm-btn-outline">Back to Dashboard</a>
                    </div>

                </form>
            </div>

            @* Info carte statut *@
            <div class="mm-card" style="max-width:600px; margin-top:16px;">
                <div style="font-size:0.85rem; color:#6b7a8d;">
                    <strong style="color:#1a2332;">Account Information</strong><br><br>
                    <span>Agent ID : </span><strong>AGT-@Model.Id.ToString("D4")</strong><br>
                    <span>Status : </span>
                    <span class="mm-badge @Model.Status.ToString().ToLower()">@Model.Status</span><br>
                    <span style="display:inline-block; margin-top:6px;">
                        Registered : @Model.RegisteredAt.ToString("dd/MM/yyyy")
                    </span>
                </div>
            </div>
        }
        else
        {
            <div class="mm-alert mm-alert-error">Agent profile not found. Please contact admin.</div>
        }

    </div>
</body>
</html>
