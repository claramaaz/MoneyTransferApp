@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="mm-auth-page">

    <div class="mm-auth-box">

        <div class="mm-auth-logo">
            <img src="~/images/logo.png" alt="Money Money Logo" />
            <h1>Money Money</h1>
            <p>Sign in to your account</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="mm-alert mm-alert-error">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post">

            <div class="mm-form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="you@email.com" required />
            </div>

            <div class="mm-form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="••••••••" required />
            </div>

            <div style="display:flex; align-items:center; gap:8px; margin-bottom:18px;">
                <input type="checkbox" name="rememberMe" id="rememberMe" style="width:auto;" />
                <label for="rememberMe" style="font-weight:400; font-size:0.88rem; color:#6b7a8d; margin-bottom:0;">Remember me</label>
            </div>

            <button type="submit" class="mm-btn mm-btn-primary mm-btn-full">Sign In</button>

        </form>

        <p class="mm-auth-footer">
            New here? <a asp-action="Register">Create an account</a>
        </p>

    </div>

</body>
</html>
