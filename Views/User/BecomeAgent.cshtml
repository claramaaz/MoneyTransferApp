@* ============================================================
   Views/User/BecomeAgent.cshtml
   Un User fait une demande pour devenir Agent
   L'Admin approuve depuis Admin/Agents
   ============================================================ *@

@{
    Layout = null;
    ViewData["Title"] = "Become an Agent";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Become an Agent - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @Html.Partial("_UserNav")
    <div class="mm-container">

        <p class="mm-page-title">Become an Agent Partner</p>
        <p class="mm-page-subtitle">Join our network and earn commissions on every transaction</p>

        @if (ViewBag.Success != null)
        {
            <div class="mm-alert mm-alert-success">@ViewBag.Success</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="mm-alert mm-alert-error">@ViewBag.Error</div>
        }

        @if (ViewBag.AlreadyApplied == true)
        {
            <div class="mm-card" style="max-width:560px; text-align:center; padding:40px;">
                <div style="font-size:2.5rem; margin-bottom:16px;">⏳</div>
                <div style="font-weight:700; font-size:1.1rem; margin-bottom:8px;">Application Submitted</div>
                <div style="color:#6b7a8d; font-size:0.9rem;">
                    Your agent application is pending admin approval.<br>
                    You will be notified once it is reviewed.
                </div>
            </div>
        }
        else
        {
            <div style="display:grid; grid-template-columns:1fr 320px; gap:24px; align-items:start;">

                @* ── Formulaire de demande ── *@
                <div class="mm-card">
                    <div style="font-weight:600; font-size:1rem; margin-bottom:4px;">Agent Registration</div>
                    <div style="font-size:0.82rem; color:#6b7a8d; margin-bottom:20px;">Fill in your details to apply as an agent partner</div>

                    <form asp-action="ApplyAsAgent" asp-controller="User" method="post">

                        <div class="mm-form-group">
                            <label>Store / Business Name *</label>
                            <input type="text" name="storeName" placeholder="Enter your store name" required />
                        </div>

                        <div class="mm-form-grid-2">
                            <div class="mm-form-group">
                                <label>Contact Name *</label>
                                <input type="text" name="ownerName" placeholder="Your full name" required />
                            </div>
                            <div class="mm-form-group">
                                <label>Phone Number *</label>
                                <input type="text" name="phone" placeholder="+961 ..." required />
                            </div>
                        </div>

                        <div class="mm-form-group">
                            <label>Business Address *</label>
                            <input type="text" name="address" placeholder="Street address" required />
                        </div>

                        <div class="mm-form-group">
                            <label>Working Hours *</label>
                            <input type="text" name="workingHours"
                                   placeholder="e.g. Mon-Fri: 9AM-6PM, Sat: 10AM-4PM" required />
                        </div>

                        <div class="mm-form-grid-2">
                            <div class="mm-form-group">
                                <label>Latitude</label>
                                <input type="number" name="latitude" step="0.0001"
                                       placeholder="33.8938" />
                            </div>
                            <div class="mm-form-group">
                                <label>Longitude</label>
                                <input type="number" name="longitude" step="0.0001"
                                       placeholder="35.5018" />
                            </div>
                        </div>

                        <button type="submit" class="mm-btn mm-btn-primary mm-btn-full"
                                style="margin-top:8px;">
                            Submit Application
                        </button>

                    </form>
                </div>

                @* ── Avantages d'être agent ── *@
                <div>
                    <div class="mm-card">
                        <div style="font-weight:600; font-size:0.95rem; margin-bottom:14px;">Benefits of becoming an agent:</div>
                        <div style="display:flex;flex-direction:column;gap:10px;">
                            <div style="display:flex;gap:10px;align-items:flex-start;font-size:0.88rem;">
                                <span style="color:#00b48c;font-size:1rem;flex-shrink:0;">✓</span>
                                <span>Earn commissions on every transaction</span>
                            </div>
                            <div style="display:flex;gap:10px;align-items:flex-start;font-size:0.88rem;">
                                <span style="color:#00b48c;font-size:1rem;flex-shrink:0;">✓</span>
                                <span>Flexible working hours</span>
                            </div>
                            <div style="display:flex;gap:10px;align-items:flex-start;font-size:0.88rem;">
                                <span style="color:#00b48c;font-size:1rem;flex-shrink:0;">✓</span>
                                <span>Full support from our team</span>
                            </div>
                            <div style="display:flex;gap:10px;align-items:flex-start;font-size:0.88rem;">
                                <span style="color:#00b48c;font-size:1rem;flex-shrink:0;">✓</span>
                                <span>Access to our technology platform</span>
                            </div>
                            <div style="display:flex;gap:10px;align-items:flex-start;font-size:0.88rem;">
                                <span style="color:#00b48c;font-size:1rem;flex-shrink:0;">✓</span>
                                <span>Listed on the agents map for customers</span>
                            </div>
                        </div>
                    </div>

                    <div class="mm-alert mm-alert-info" style="margin-top:12px; font-size:0.78rem;">
                        <strong>Note:</strong> Applications are reviewed by admin within 24-48 hours.
                        You will receive a notification once approved.
                    </div>
                </div>

            </div>
        }

    </div>
</body>
</html>
