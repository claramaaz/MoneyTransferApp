@model IEnumerable<MoneyTransferApp.Models.Agent>

@{
    ViewData["Title"] = "Agents";
    Layout = null;
}
@Html.Partial("_AdminNav")
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Agents — Money Money Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        html, body { height:100%; font-family:'Segoe UI',sans-serif; background:#f0f4f8; color:#1a202c; }
        .page-wrapper { display:flex; min-height:100vh; }
        .sidebar { width:230px; min-height:100vh; flex-shrink:0; background:linear-gradient(180deg,#0d1b2a,#1a2744); display:flex; flex-direction:column; box-shadow:3px 0 15px rgba(0,0,0,0.25); }
        .sidebar-brand { display:flex; align-items:center; gap:10px; padding:20px 18px 16px; border-bottom:1px solid rgba(255,255,255,0.08); text-decoration:none; }
        .sidebar-brand img { width:36px; height:36px; }
        .sidebar-brand-text .name { color:#fff; font-size:1.05rem; font-weight:700; }
        .sidebar-brand-text .role { color:rgba(255,255,255,0.45); font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; }
        .sidebar-nav { padding:14px 10px; flex:1; }
        .sidebar-nav a { display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:8px; margin-bottom:3px; color:rgba(255,255,255,0.65); text-decoration:none; font-size:0.88rem; font-weight:500; transition:all 0.18s; }
        .sidebar-nav a:hover, .sidebar-nav a.active { background:rgba(26,115,232,0.25); color:#fff; }
        .sidebar-nav a .icon { font-size:1.05rem; width:20px; text-align:center; }
        .sidebar-label { font-size:0.68rem; text-transform:uppercase; letter-spacing:1.5px; color:rgba(255,255,255,0.28); padding:12px 12px 4px; font-weight:600; }
        .sidebar-footer { padding:14px 18px; border-top:1px solid rgba(255,255,255,0.08); }
        .sidebar-footer form button { width:100%; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.15); color:rgba(255,255,255,0.7); padding:9px; border-radius:8px; cursor:pointer; font-size:0.86rem; font-weight:500; transition:all 0.18s; }
        .sidebar-footer form button:hover { background:rgba(211,47,47,0.3); color:#fff; }
        .main { flex:1; display:flex; flex-direction:column; }
        .topbar { background:#fff; padding:14px 28px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #e2e8f0; box-shadow:0 1px 4px rgba(0,0,0,0.06); }
        .topbar-title { font-size:1.15rem; font-weight:700; }
        .topbar-user { font-size:0.85rem; color:#718096; }
        .content { padding:24px 28px; }
        .section-title { font-size:1rem; font-weight:700; color:#2d3748; margin-bottom:14px; padding-left:10px; border-left:3px solid #1a73e8; }
        .table-card { background:#fff; border-radius:12px; overflow:hidden; box-shadow:0 1px 8px rgba(0,0,0,0.07); }
        .table-card table { width:100%; border-collapse:collapse; }
        .table-card thead th { background:linear-gradient(135deg,#1a73e8,#0d5bca); color:#fff; padding:11px 16px; text-align:left; font-size:0.82rem; font-weight:600; text-transform:uppercase; }
        .table-card tbody td { padding:11px 16px; border-bottom:1px solid #f0f4f8; font-size:0.9rem; }
        .table-card tbody tr:last-child td { border-bottom:none; }
        .table-card tbody tr:hover td { background:#f7faff; }
        .badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.76rem; font-weight:600; }
        .badge-pending  { background:#fff3e0; color:#e65100; }
        .badge-approved { background:#e6f4ea; color:#1e7e34; }
        .badge-rejected { background:#fce8e8; color:#c62828; }
        .btn { padding:6px 13px; border:none; border-radius:6px; cursor:pointer; font-size:0.82rem; font-weight:600; transition:opacity 0.18s; }
        .btn-success { background:linear-gradient(135deg,#2e7d32,#43a047); color:#fff; }
        .btn-danger  { background:#d32f2f; color:#fff; }
        .btn:hover   { opacity:0.88; }
        .card { background:#fff; border-radius:12px; padding:22px; box-shadow:0 1px 8px rgba(0,0,0,0.07); }
    </style>
</head>
<body>
<div class="page-wrapper">
    <aside class="sidebar">
        <a class="sidebar-brand" asp-controller="Admin" asp-action="Dashboard">
            <img src="~/images/logo.png" alt="Logo" />
            <div class="sidebar-brand-text"><div class="name">Money Money</div><div class="role">Admin Panel</div></div>
        </a>
        <nav class="sidebar-nav">
            <div class="sidebar-label">Main</div>
            <a asp-controller="Admin" asp-action="Dashboard"><span class="icon">📊</span> Overview</a>
            <div class="sidebar-label">Management</div>
            <a asp-controller="Admin" asp-action="Agents" class="active"><span class="icon">🏪</span> Agents</a>
            <a asp-controller="Admin" asp-action="Users"><span class="icon">👥</span> Users</a>
            <div class="sidebar-label">Finance</div>
            <a asp-controller="Admin" asp-action="Commissions"><span class="icon">💰</span> Commissions</a>
            <a asp-controller="Admin" asp-action="Currencies"><span class="icon">💱</span> Currencies</a>
            <a asp-controller="Admin" asp-action="Reports"><span class="icon">📈</span> Reports</a>
        </nav>
        <div class="sidebar-footer">
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit">🚪 Logout</button>
            </form>
        </div>
    </aside>
    <main class="main">
        <div class="topbar">
            <div class="topbar-title">Manage Agents</div>
            <div class="topbar-user">Admin · @DateTime.Now.ToString("dd MMM yyyy")</div>
        </div>
        <div class="content">
            <p class="section-title">Agent Applications</p>
            @if (Model == null || !Model.Any())
            {
                <div class="card"><p style="color:#a0aec0;">No agents registered yet.</p></div>
            }
            else
            {
                <div class="table-card">
                    <table>
                        <thead>
                            <tr><th>ID</th><th>Store Name</th><th>Contact</th><th>Address</th><th>Status</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var agent in Model)
                            {
                                <tr>
                                    <td>@agent.Id</td>
                                    <td><strong>@agent.StoreName</strong></td>
                                    <td>@agent.OwnerName</td>
                                    <td>@agent.Address</td>
                                    <td><span class="badge badge-@agent.Status.ToString().ToLower()">@agent.Status</span></td>
                                    <td>
                                        @if (agent.Status == MoneyTransferApp.Models.AgentStatus.Pending)
                                        {
                                            <form asp-action="ApproveAgent" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@agent.Id" />
                                                <button type="submit" class="btn btn-success">✓ Approve</button>
                                            </form>
                                            <form asp-action="RejectAgent" method="post" style="display:inline; margin-left:6px;">
                                                <input type="hidden" name="id" value="@agent.Id" />
                                                <button type="submit" class="btn btn-danger">✕ Reject</button>
                                            </form>
                                        }
                                        else { <span style="color:#a0aec0; font-size:0.85rem;">—</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </main>
</div>
</body>
</html>
