@* ============================================================
   Views/Agent/Support.cshtml — VERSION PROPRE
   Sans les faux "Active Chats" hardcodés
   ============================================================ *@

@{
    Layout = null;
    ViewData["Title"] = "Customer Support";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Support - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .chat-wrapper { max-width: 780px; margin: 0 auto; }
        .chat-window { background:white; border-radius:14px; border:1px solid #e2e8f0; display:flex; flex-direction:column; min-height:520px; }
        .chat-win-header { padding:16px 22px; border-bottom:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center; }
        .chat-win-header .title { font-weight:600; font-size:1rem; }
        .chat-win-header .bot-badge { font-size:0.78rem; color:#1490dc; font-weight:500; background:rgba(20,144,220,0.08); padding:4px 12px; border-radius:20px; }
        .chat-messages { flex:1; padding:22px; display:flex; flex-direction:column; gap:14px; overflow-y:auto; max-height:400px; }
        .msg-wrap { display:flex; flex-direction:column; }
        .msg { max-width:75%; padding:11px 15px; border-radius:12px; font-size:0.88rem; line-height:1.6; }
        .msg.user { background:#f0f4f8; color:#1a2332; align-self:flex-end; border-bottom-right-radius:4px; }
        .msg.bot  { background:rgba(20,144,220,0.07); color:#1a2332; align-self:flex-start; border:1px solid rgba(20,144,220,0.15); border-bottom-left-radius:4px; }
        .msg.typing { background:rgba(20,144,220,0.05); color:#6b7a8d; align-self:flex-start; font-style:italic; }
        .msg-meta { font-size:0.7rem; color:#6b7a8d; margin-top:3px; }
        .meta-right { text-align:right; }
        .chat-input-row { padding:14px 18px; border-top:1px solid #e2e8f0; display:flex; gap:10px; align-items:center; }
        .chat-input { flex:1; padding:10px 14px; border:1.5px solid #e2e8f0; border-radius:8px; font-size:0.88rem; font-family:inherit; outline:none; }
        .chat-input:focus { border-color:#1490dc; }
        .chat-send { background:#1490dc; color:white; border:none; padding:10px 18px; border-radius:8px; cursor:pointer; font-size:0.95rem; transition:opacity 0.15s; }
        .chat-send:hover { opacity:0.85; }
        .chat-send:disabled { opacity:0.4; cursor:not-allowed; }
        .quick-btns { display:flex; flex-wrap:wrap; gap:8px; padding:0 22px 14px; }
        .quick-btn { background:#f0f7ff; border:1px solid rgba(20,144,220,0.25); color:#1490dc; border-radius:20px; padding:5px 14px; font-size:0.8rem; cursor:pointer; transition:all 0.15s; }
        .quick-btn:hover { background:#1490dc; color:white; }
    </style>
</head>
<body>

@Html.Partial("_AgentNav")

<div class="mm-container">

    <p class="mm-page-title">Customer Support</p>
    <p class="mm-page-subtitle">AI-powered assistant — helps you answer customer questions instantly</p>

    <div class="chat-wrapper">
        <div class="chat-window">
            <div class="chat-win-header">
                <span class="title">🤖 Money Money Support Bot</span>
            </div>

            <div class="chat-messages" id="chatMessages">
                <div class="msg-wrap">
                    <div class="msg bot">
                        <strong style="font-size:0.78rem;color:#0e72b0;">🤖 Support Bot</strong><br>
                        Hello! I'm the Money Money AI support assistant.<br>
                        I can help with <strong>transactions</strong>, <strong>balances</strong>, <strong>cash operations</strong>, <strong>currency rates</strong>, and more.<br><br>
                        How can I help you today?
                    </div>
                    <div class="msg-meta">now</div>
                </div>
            </div>

            <!-- Quick reply buttons -->
            <div class="quick-btns">
                <button class="quick-btn" onclick="quickSend('What are the commission fees?')">Commission fees</button>
                <button class="quick-btn" onclick="quickSend('How do I track a transfer?')">Track transfer</button>
                <button class="quick-btn" onclick="quickSend('What currencies are supported?')">Currencies</button>
                <button class="quick-btn" onclick="quickSend('How does cash-in work?')">Cash-in help</button>
            </div>

            <div class="chat-input-row">
                <input class="chat-input" id="msgInput" type="text"
                       placeholder="Type your message or question..." autocomplete="off" />
                <button class="chat-send" id="sendBtn" onclick="sendMessage()">&#9658;</button>
            </div>
        </div>
    </div>
</div>

<script>
    var conversationHistory = [];

    function now() {
        return new Date().toLocaleTimeString('en', { hour: '2-digit', minute: '2-digit' });
    }

    function appendMsg(container, type, html, time) {
        var wrap = document.createElement('div');
        wrap.className = 'msg-wrap';
        wrap.innerHTML =
            '<div class="msg ' + type + '">' + html + '</div>' +
            '<div class="msg-meta ' + (type === 'user' ? 'meta-right' : '') + '">' + time + '</div>';
        container.appendChild(wrap);
        container.scrollTop = container.scrollHeight;
    }

    function quickSend(text) {
        document.getElementById('msgInput').value = text;
        sendMessage();
    }

    async function sendMessage() {
        var input = document.getElementById('msgInput');
        var sendBtn = document.getElementById('sendBtn');
        var msg = input.value.trim();
        if (!msg) return;

        var c = document.getElementById('chatMessages');
        appendMsg(c, 'user', msg, now());
        input.value = '';
        sendBtn.disabled = true;

        var typingWrap = document.createElement('div');
        typingWrap.id = 'typing';
        typingWrap.innerHTML = '<div class="msg typing">🤖 Support Bot is typing...</div>';
        c.appendChild(typingWrap);
        c.scrollTop = c.scrollHeight;

        conversationHistory.push({ role: 'user', content: msg });

        try {
            var response = await fetch('/Agent/ChatProxy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: conversationHistory })
            });

            var data = await response.json();

            var typingEl = document.getElementById('typing');
            if (typingEl) typingEl.remove();

            if (data.reply) {
                conversationHistory.push({ role: 'assistant', content: data.reply });
                appendMsg(c, 'bot',
                    '<strong style="font-size:0.78rem;color:#0e72b0;">🤖 Support Bot</strong><br>' +
                    data.reply.replace(/\n/g, '<br>'),
                    now());
            } else {
                throw new Error('empty reply');
            }
        } catch (err) {
            var typingEl = document.getElementById('typing');
            if (typingEl) typingEl.remove();
            appendMsg(c, 'bot',
                '<strong style="font-size:0.78rem;color:#b91c1c;">⚠ Bot</strong><br>' +
                'Sorry, I\'m temporarily unavailable. Please try again.',
                now());
        }

        sendBtn.disabled = false;
        input.focus();
    }

    document.getElementById('msgInput').addEventListener('keypress', function (e) {
        if (e.key === 'Enter' && !document.getElementById('sendBtn').disabled)
            sendMessage();
    });
</script>

</body>
</html>
