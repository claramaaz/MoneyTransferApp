@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account - Money Money</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="mm-auth-page">

    <div class="mm-auth-box">

        <div class="mm-auth-logo">
            <img src="~/images/logo.png" alt="Money Money Logo" />
            <h1>Money Money</h1>
            <p>Create your account</p>
        </div>

        <div asp-validation-summary="All" style="font-size:0.85rem; color:#b91c1c; margin-bottom:12px;"></div>

        <form asp-action="Register" method="post">

            <div class="mm-form-group">
                <label>Full Name</label>
                <input type="text" name="fullName" placeholder="John Doe" required />
            </div>

            <div class="mm-form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="you@email.com" required />
            </div>

            <div class="mm-form-group">
                <label>Preferred Currency</label>
                <select name="preferredCurrency">
                    <option value="USD">🇺🇸 USD — US Dollar</option>
                    <option value="EUR">🇪🇺 EUR — Euro</option>
                    <option value="LBP">🇱🇧 LBP — Lebanese Pound</option>
                    <option value="AED">🇦🇪 AED — UAE Dirham</option>
                    <option value="SAR">🇸🇦 SAR — Saudi Riyal</option>
                    <option value="GBP">🇬🇧 GBP — British Pound</option>
                </select>
            </div>

            <div class="mm-form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Min 8 characters" required />
            </div>

            <button type="submit" class="mm-btn mm-btn-primary mm-btn-full">Create Account</button>

        </form>

        <p class="mm-auth-footer">
            Already have an account? <a asp-action="Login">Sign in</a>
        </p>

    </div>

</body>
</html>
